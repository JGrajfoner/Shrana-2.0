<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ozadje"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Uredi recept"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/besedilo_primarno"
            android:layout_marginBottom="24dp" />

        <TextView
            style="@style/NaslovRazdelka"
            android:text="NASLOV" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Polje"
            android:layout_marginBottom="16dp"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/vnosNaslov"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Naslov recepta"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            style="@style/NaslovRazdelka"
            android:text="SLIKA" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <com.google.android.material.card.MaterialCardView
                style="@style/Kartica"
                android:layout_width="100dp"
                android:layout_height="100dp"
                app:cardCornerRadius="12dp">

                <ImageView
                    android:id="@+id/slikaPredogled"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:contentDescription="Predogled slike" />
            </com.google.android.material.card.MaterialCardView>

            <Button
                android:id="@+id/gumbIzberiSliko"
                style="@style/Gumb.Tonalni"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Izberi sliko" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/NaslovRazdelka"
                    android:text="ČAS PRIPRAVE" />

                <Button
                    android:id="@+id/gumbCasPriprave"
                    style="@style/Gumb.Tonalni"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0 min" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    style="@style/NaslovRazdelka"
                    android:text="ČAS KUHANJA" />

                <Button
                    android:id="@+id/gumbCasKuhanja"
                    style="@style/Gumb.Tonalni"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0 min" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            style="@style/NaslovRazdelka"
            android:text="KALORIJE" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Polje"
            android:layout_marginBottom="16dp"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/vnosKalorije"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="kcal"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            style="@style/NaslovRazdelka"
            android:text="OPIS" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Polje"
            android:layout_marginBottom="16dp"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/vnosOpis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Kratek opis recepta"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:gravity="top" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            style="@style/NaslovRazdelka"
            android:text="SESTAVINE" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Polje"
                android:layout_width="0dp"
                android:layout_weight="2"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/vnosImeSestavine"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ime"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Polje"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/vnosKolicinaSestavine"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Kol."
                    android:inputType="numberDecimal" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.5"
                android:layout_marginStart="6dp"
                app:hintEnabled="false">

                <AutoCompleteTextView
                    android:id="@+id/autoCompleteEnota"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/gumbDodajSestavino"
                style="@style/Gumb.Tonalni"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/seznamSestavinKontejner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp" />

        <TextView
            style="@style/NaslovRazdelka"
            android:text="OZNAKE" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Polje"
                android:layout_width="0dp"
                android:layout_weight="1"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/vnosOznaka"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Vnesi oznako"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/gumbDodajOznako"
                style="@style/Gumb.Tonalni"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupOznake"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <TextView
            style="@style/NaslovRazdelka"
            android:text="PRIPRAVA" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Polje"
            android:layout_marginBottom="24dp"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/vnosPriprava"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Opišite postopek priprave..."
                android:inputType="textMultiLine"
                android:minLines="5"
                android:gravity="top" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/gumbPreklici"
                style="@style/Gumb.Opozorilo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Prekliči" />

            <Button
                android:id="@+id/gumbPosodobi"
                style="@style/Gumb.Primarni"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Posodobi" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>