<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ozadje"
    android:fitsSystemWindows="true">

    <TextView
        style="@style/NaslovZaslona"
        android:text="Časovniki" />

    <!-- FrameLayout: seznam in prazno navodilo se prekrivata -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/seznamCasovnikov"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="88dp" />

        <!-- Navodilo na sredini, vidno ko ni časovnikov -->
        <TextView
            android:id="@+id/praznoNavodilo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Dodajte časovnik s klikom na + Dodaj"
            android:textSize="16sp"
            android:textColor="@color/namig"
            android:gravity="center"
            android:padding="32dp" />

    </FrameLayout>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/gumbDodaj"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_margin="16dp"
        android:text="+ Dodaj"
        android:textColor="@color/na_primarni"
        app:backgroundTint="@color/primarna" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/spodnjaNavigacija"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/povrsina"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled" />

</LinearLayout>