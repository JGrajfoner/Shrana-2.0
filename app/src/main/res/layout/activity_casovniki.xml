<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Časovniki"
        android:textSize="26sp"
        android:textStyle="bold"
        android:padding="16dp" />

    <!-- FrameLayout: seznam in prazno navodilo se prekrivata -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/seznamCasovnikov"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Navodilo na sredini, vidno ko ni časovnikov -->
        <TextView
            android:id="@+id/praznoNavodilo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Dodajte časovnik s klikom na + Dodaj"
            android:textSize="18sp"
            android:textColor="#999999"
            android:gravity="center"
            android:padding="32dp" />

    </FrameLayout>

    <Button
        android:id="@+id/gumbDodaj"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_margin="16dp"
        android:text="+ Dodaj"
        android:backgroundTint="#FFEB3B"
        android:textColor="#000000" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/spodnjaNavigacija"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled" />

</LinearLayout>