<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Ime obroka: Zajtrk / Kosilo / Večerja -->
    <TextView
        android:id="@+id/imeObroka"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:text="Zajtrk"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/besedilo_primarno" />

    <!-- Ime izbranega recepta (vidno, če je obrok določen) -->
    <TextView
        android:id="@+id/imeRecepta"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="-"
        android:textSize="16sp"
        android:textColor="@color/besedilo_sekundarno" />

    <!-- Gumb × za odstranitev izbranega recepta -->
    <ImageButton
        android:id="@+id/gumbOdstrani"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:tint="@color/opozorilo"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Odstrani recept" />

    <!-- Gumb + (viden, če obrok še ni določen) -->
    <ImageButton
        android:id="@+id/gumbDodaj"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/add_24px"
        app:tint="@color/primarna"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Dodaj recept" />

</LinearLayout>