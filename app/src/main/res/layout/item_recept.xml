<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="90dp"
        android:layout_height="75dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <ImageView
            android:id="@+id/slikaRecepta"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_image"
            android:scaleType="centerCrop"
            android:contentDescription="Slika recepta" />

    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="16dp">

        <TextView
            android:id="@+id/naslovRecepta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Naslov recepta"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="?android:attr/textColorPrimary" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/casRecepta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="45m"
                android:textSize="13sp"
                android:drawableStart="@drawable/timer_24px"
                android:drawablePadding="6dp"
                android:drawableTint="?android:attr/textColorSecondary" />

            <TextView
                android:id="@+id/kalorijeRecepta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="450 kcal"
                android:textSize="13sp"
                android:layout_marginStart="12dp"
                android:drawableStart="@drawable/local_fire_department_24px"
                android:drawablePadding="6dp"
                android:drawableTint="?android:attr/textColorSecondary" />
        </LinearLayout>

        <TextView
            android:id="@+id/opisRecepta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Okusen recept"
            android:textSize="13sp"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="?android:attr/textColorSecondary" />
    </LinearLayout>

    <ImageView
        android:id="@+id/srcek"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_star_outline"
        android:contentDescription="Priljubljeno"
        android:padding="8dp"
        android:background="?attr/selectableItemBackgroundBorderless" />

</LinearLayout>