<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ozadje"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <ImageButton
                android:id="@+id/gumbNazaj"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/arrow_back_24px"
                app:tint="@color/besedilo_primarno"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Nazaj"
                android:layout_alignParentStart="true" />

            <ImageButton
                android:id="@+id/gumbUredi"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/edit_24px"
                app:tint="@color/primarna"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Uredi"
                android:layout_alignParentEnd="true" />

        </RelativeLayout>

        <com.google.android.material.card.MaterialCardView
            style="@style/Kartica"
            android:layout_width="match_parent"
            android:layout_height="220dp">

            <ImageView
                android:id="@+id/slika"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_image"
                android:scaleType="centerCrop"
                android:contentDescription="Slika recepta" />

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/naslov"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Ime recepta"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:textColor="@color/besedilo_primarno" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupOznakePrikaz"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/opis"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Kratek opis recepta"
            android:textSize="16sp"
            android:layout_marginTop="8dp"
            android:textColor="@color/besedilo_sekundarno" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@+id/casPriprave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                tools:text="Priprava: 15 min"
                android:textSize="14sp"
                android:textColor="@color/besedilo_sekundarno"
                app:drawableStartCompat="@drawable/grocery_24px"
                android:drawablePadding="8dp"
                app:drawableTint="@color/primarna" />

            <TextView
                android:id="@+id/casKuhanja"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                tools:text="Kuhanje: 30 min"
                android:textSize="14sp"
                android:textColor="@color/besedilo_sekundarno"
                app:drawableStartCompat="@drawable/skillet_24px"
                android:drawablePadding="8dp"
                app:drawableTint="@color/primarna" />
        </LinearLayout>

        <TextView
            android:id="@+id/kalorijePrikaz"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="450 kcal"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:textColor="@color/besedilo_sekundarno"
            app:drawableStartCompat="@drawable/local_fire_department_24px"
            android:drawablePadding="8dp"
            app:drawableTint="@color/primarna" />

        <View
            style="@style/Locnica"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SESTAVINE"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/besedilo_primarno" />

            <Button
                android:id="@+id/gumbNaSeznam"
                style="@style/Gumb.Tekstovni"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="na seznam"
                app:icon="@drawable/add_shopping_cart_24px" />
        </LinearLayout>

        <TextView
            android:id="@+id/sestavine"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-"
            android:textSize="16sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginTop="8dp"
            android:textColor="@color/besedilo_primarno" />

        <View
            style="@style/Locnica"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PRIPRAVA"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/besedilo_primarno" />

        <TextView
            android:id="@+id/priprava"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-"
            android:textSize="16sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginTop="8dp"
            android:textColor="@color/besedilo_primarno" />

    </LinearLayout>
</ScrollView>