<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:fitsSystemWindows="true">

        <!-- Lasten gumb nazaj (puščica levo zgoraj) -->
        <ImageButton
            android:id="@+id/gumbNazaj"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="Nazaj"
            android:layout_marginBottom="8dp" />

        <!-- Slika recepta -->
        <ImageView
            android:id="@+id/slika"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="#EEEEEE"
            android:src="@android:drawable/ic_menu_gallery"
            android:scaleType="centerCrop" />

        <!-- Ime recepta -->
        <TextView
            android:id="@+id/naslov"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ime recepta"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <!-- Kratek opis -->
        <TextView
            android:id="@+id/opis"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kratek opis recepta"
            android:textSize="16sp"
            android:layout_marginTop="4dp" />

        <!-- Čas -->
        <TextView
            android:id="@+id/cas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🕐 čas"
            android:textSize="14sp"
            android:layout_marginTop="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <!-- Sestavine -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SESTAVINE"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/gumbNaSeznam"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛒 na seznam"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/sestavine"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-"
            android:textSize="16sp"
            android:layout_marginTop="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <!-- Priprava -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PRIPRAVA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/priprava"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-"
            android:textSize="16sp"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>