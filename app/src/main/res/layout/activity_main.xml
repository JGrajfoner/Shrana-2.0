<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ozadje"
    android:fitsSystemWindows="true">

    <TextView
        style="@style/NaslovZaslona"
        android:text="Recepti" />

    <!-- Zgornja vrstica: iskanje + filter + priljubljeni -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:hintEnabled="false"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
            app:startIconDrawable="@drawable/ic_search"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/iskalnik"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Išči ..."
                android:inputType="text"
                android:paddingTop="10dp"
                android:paddingBottom="10dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <ImageButton
            android:id="@+id/gumbFilter"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_filter"
            app:tint="@color/besedilo_sekundarno"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Filter" />

        <ImageButton
            android:id="@+id/gumbPriljubljeni"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_star_outline"
            app:tint="@color/primarna"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Priljubljeni" />
    </LinearLayout>

    <!-- FrameLayout dovoli, da gumb "lebdi" nad seznamom (desno spodaj) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/seznamReceptov"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="88dp" />

        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/gumbDodaj"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:text="+ Dodaj"
            android:textColor="@color/na_primarni"
            app:backgroundTint="@color/primarna" />

    </FrameLayout>

    <!-- Spodnja navigacija -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/spodnjaNavigacija"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/povrsina"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled" />

</LinearLayout>