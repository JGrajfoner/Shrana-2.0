<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- Zgornja vrstica: iskanje + filter + priljubljeni -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:hintEnabled="false"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
            app:startIconDrawable="@drawable/ic_search"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/iskalnik"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Išči ..."
                android:inputType="text"
                android:paddingTop="10dp"
                android:paddingBottom="10dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <ImageButton
            android:id="@+id/gumbFilter"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_filter"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="Filter" />

        <ImageButton
            android:id="@+id/gumbPriljubljeni"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_star_outline"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="Priljubljeni" />
    </LinearLayout>

    <!-- FrameLayout dovoli, da gumb "lebdi" nad seznamom (desno spodaj) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/seznamReceptov"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp" />

        <!-- Gumb Dodaj z napisom in ikono, kot na strani za časovnike -->
        <Button
            android:id="@+id/gumbDodaj"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:text="+ Dodaj"
            android:backgroundTint="#FFEB3B"
            android:textColor="#000000"
            android:textAllCaps="false" />

    </FrameLayout>

    <!-- Spodnja navigacija -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/spodnjaNavigacija"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled" />

</LinearLayout>