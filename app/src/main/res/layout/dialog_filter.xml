<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/ozadje">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ===== Oznake ===== -->
        <TextView
            style="@style/NaslovRazdelka"
            android:text="OZNAKE" />

        <TextView
            android:id="@+id/oznakePrazno"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ni oznak"
            android:textColor="@color/namig"
            android:textSize="14sp"
            android:visibility="gone" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="false"
            android:layout_marginBottom="20dp" />

        <!-- ===== Čas (priprava + kuhanje) ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                style="@style/NaslovRazdelka"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="NAJVEČ ČASA" />

            <TextView
                android:id="@+id/oznakaCas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="–"
                android:textColor="@color/primarna"
                android:textStyle="bold"
                android:textSize="14sp" />
        </LinearLayout>

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderCas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:stepSize="5"
            android:valueFrom="0"
            android:valueTo="240"
            android:value="240" />

        <!-- ===== Kalorije ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                style="@style/NaslovRazdelka"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="NAJVEČ KALORIJ" />

            <TextView
                android:id="@+id/oznakaKalorije"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="–"
                android:textColor="@color/primarna"
                android:textStyle="bold"
                android:textSize="14sp" />
        </LinearLayout>

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderKalorije"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:stepSize="50"
            android:valueFrom="0"
            android:valueTo="2000"
            android:value="2000" />

    </LinearLayout>
</ScrollView>